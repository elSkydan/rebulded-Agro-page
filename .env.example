# Copy to .env and adjust. Special characters in passwords in DATABASE_URL must be URL-encoded (e.g. @ -> %40, # -> %23, ! -> %21).

# Option A — single connection string (preferred if your password is simple or encoded)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/lead_distribution

# Option B — omit DATABASE_URL and use discrete vars (avoids URL-encoding issues)
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=lead_distribution
# PGUSER=postgres

# Telegram Bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=8794291045:AAErql98V5-D5aOFAmOBiqrZg-peJvnGrRg

# Telegram chat_id of the admin user
ADMIN_CHAT_ID=197656058

# Bearer token for admin API endpoints
ADMIN_TOKEN=124321345123sedafasdfasd(*asdfasd


# Public HTTPS base URL of this server.
# Required in production (NODE_ENV=production).
# Required for: npm run telegram:setup  (registers the Telegram webhook).
# For local dev: set to your ngrok/Cloudflare Tunnel URL.
#   e.g.  PUBLIC_BASE_URL=https://abc123.ngrok-free.app
# The webhook will be registered at: $PUBLIC_BASE_URL/api/telegram/webhook
PUBLIC_BASE_URL=https://lunacy-staining-abstain.ngrok-free.dev

# Optional (see README)
# PORT=3000
# HOST=0.0.0.0
# CORS_ORIGIN accepts: '*', a single origin, or a comma-separated list.
# CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173

